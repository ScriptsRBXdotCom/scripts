-- ===================== EVENTS =====================
EventTab:CreateSection("Auto Farm")

local autoEggs = false

EventTab:CreateToggle({
	Name = "Auto Collect Easter Eggs",
	CurrentValue = false,
	Callback = function(v)
		autoEggs = v
		if v then
			task.spawn(function()
				while autoEggs do
					for _, egg in pairs(workspace.Events.EasterEggs:GetChildren()) do
						if not autoEggs then break end

						local cube = egg:FindFirstChild("Cube")
						local prompt = cube and cube:FindFirstChild("PickUpPrompt")

						if cube and prompt then
							player.Character.HumanoidRootPart.CFrame = cube.CFrame + Vector3.new(0,3,0)
							task.wait(0.2)
							fireproximityprompt(prompt)
							task.wait(0.3)
						end
					end
					task.wait(1)
				end
			end)
		end
	end
})
