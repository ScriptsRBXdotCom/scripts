-- ===================== BRAINROT UI SYSTEM =====================

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local BrainrotFolder = workspace:WaitForChild("Brainrots")

local SelectedBrainrot = nil
local SelectedRarity = "All"

local BrainrotDropdown

-- ===================== GET DATA =====================

local function getBrainrots()
    local list = {}

    for _, brainrot in ipairs(BrainrotFolder:GetChildren()) do
        if brainrot:IsA("Model") then
            
            local rarity = brainrot:GetAttribute("Rarity") or "Unknown"
            local mutation = brainrot:GetAttribute("Mutation") or "None"
            local name = brainrot:GetAttribute("Index") or brainrot.Name

            -- filter by rarity
            if SelectedRarity == "All" or rarity == SelectedRarity then
                table.insert(list, name .. " | " .. rarity .. " | " .. mutation)
            end
        end
    end

    return list
end

-- find actual model from string
local function findBrainrotFromString(str)
    for _, brainrot in ipairs(BrainrotFolder:GetChildren()) do
        if brainrot:IsA("Model") then
            local name = brainrot:GetAttribute("Index") or brainrot.Name
            local rarity = brainrot:GetAttribute("Rarity") or "Unknown"
            local mutation = brainrot:GetAttribute("Mutation") or "None"

            local full = name .. " | " .. rarity .. " | " .. mutation

            if full == str then
                return brainrot
            end
        end
    end
end

