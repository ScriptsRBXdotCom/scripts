-- ===================== BRAINROT ZONE SYSTEM =====================

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local BrainrotsFolder = workspace:WaitForChild("Brainrots")

local SelectedZone = "Zone1"
local SelectedBrainrot = nil

local BrainrotDropdown

-- ===================== HELPERS =====================

local function getZoneFolder()
    return BrainrotsFolder:FindFirstChild(SelectedZone)
end

local function getBrainrotsInZone()
    local zone = getZoneFolder()
    if not zone then return {} end

    local list = {}

    for _, brainrot in ipairs(zone:GetChildren()) do
        if brainrot:IsA("Model") then
            table.insert(list, brainrot.Name)
        end
    end

    return list
end

local function findBrainrot(name)
    local zone = getZoneFolder()
    if not zone then return end

    return zone:FindFirstChild(name)
end

local function tpTo(model)
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")

    local cf

    if model:IsA("Model") then
        -- BEST method (works even without PrimaryPart)
        cf = model:GetPivot()
    elseif model:IsA("BasePart") then
        cf = model.CFrame
    end

    if cf then
        hrp.CFrame = cf + Vector3.new(0, 3, 0)
    else
        warn("No CFrame found for:", model.Name)
    end
end
