-- ===================== TELEPORT BUTTON =====================

Tab:CreateButton({
    Name = "Teleport to Brainrot",
    Callback = function()
        if not SelectedBrainrot then
            Rayfield:Notify({
                Title = "Error",
                Content = "Select a brainrot first",
                Duration = 2
            })
            return
        end

        local brainrot = findBrainrot(SelectedBrainrot)

        if brainrot then
            tpTo(brainrot)

            Rayfield:Notify({
                Title = "Teleported",
                Content = SelectedZone .. " → " .. SelectedBrainrot,
                Duration = 2
            })
        else
            Rayfield:Notify({
                Title = "Error",
                Content = "Brainrot not found",
                Duration = 2
            })
        end
    end,
})

Tab:CreateButton({
