			end
		end)
	end,
})
-- ===================== Lucky Block Teleport =====================
local Players = game:GetService("Players")
local player = Players.LocalPlayer

local function getRoot()
	local char = player.Character or player.CharacterAdded:Wait()
	return char:WaitForChild("HumanoidRootPart")
end

local friendsFolder = workspace:WaitForChild("Live"):WaitForChild("Friends")

-- 🔥 get unique block names
local function getUniqueBlocks()
	local seen = {}
	local list = {}

	for _, obj in pairs(friendsFolder:GetChildren()) do
		if not seen[obj.Name] then
			seen[obj.Name] = true
			table.insert(list, obj.Name)
		end
	end

	return list
end

local selectedBlock = nil

-- Dropdown
local Dropdown = Tab:CreateDropdown({
	Name = "Select Lucky Block",
	Options = getUniqueBlocks(),
	CurrentOption = {},
	MultipleOptions = false,
	Callback = function(Option)
		selectedBlock = Option[1]
	end,
})

-- Refresh button (in case blocks change)
Tab:CreateButton({
	Name = "Refresh Lucky Blocks",
	Callback = function()
		Dropdown:Refresh(getUniqueBlocks())
	end,
})

-- Teleport button
Tab:CreateButton({
	Name = "Teleport To Lucky Block",
	Callback = function()
		if not selectedBlock then return end

		local root = getRoot()

		for _, obj in pairs(friendsFolder:GetChildren()) do
			if obj.Name == selectedBlock and obj:IsA("Model") then
				if obj:FindFirstChild("HumanoidRootPart") then
					root.CFrame = obj.HumanoidRootPart.CFrame + Vector3.new(0, 3, 0)
					break
				elseif obj.PrimaryPart then
					root.CFrame = obj.PrimaryPart.CFrame + Vector3.new(0, 3, 0)
					break
				end
			end
		end
	end,
})

